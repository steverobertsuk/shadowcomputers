---
import ErrorLayout from '../layouts/ErrorLayout.astro';
---

<ErrorLayout
  errorCode={"500"}
  errorTitle={"Server Error"}
  errorDesc={"Something went wrong on our end. We're working to fix it."}
>
<section class="error-page" aria-labelledby="error-title">
  <div class="container">
    <p class="error-code" aria-hidden="true">500</p>
    <h1 class="error-title" id="error-title">Server Error</h1>
    <p class="error-desc">
      Something went wrong on our end. We're aware of the issue and working to
      fix it. Please try again in a few minutes.
    </p>
    <!-- Cloudflare replaces this token with its diagnostic box when this page
         is served from the zone's "5XX Errors" custom error page slot. -->
    <div class="cf-error-details">::CLOUDFLARE_ERROR_500S_BOX::</div>
    <a href="https://shadowcomputers.co.uk/" class="btn-primary">Return to Homepage</a>
  </div>
</section>
</ErrorLayout>
