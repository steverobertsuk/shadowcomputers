<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  {% set pageTitle %}{% if title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}{% endset %}
  {% set pageDesc = description | default(site.description) %}
  {% set pageImage = site.url ~ '/images/og-image.png' %}

  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDesc }}" />
  <meta name="author" content="Steve Roberts" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

  <!-- Favicon & icons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="16x16" href="/images/icon-16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/images/icon-32.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/images/icon-48.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/images/icon-180.png" />

  <!-- Web app manifest -->
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="{{ site.themeColor }}" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:site_name" content="{{ site.name }}" />
  <meta property="og:title" content="{{ pageTitle }}" />
  <meta property="og:description" content="{{ pageDesc }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:image" content="{{ pageImage }}" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="{{ site.name }} — {{ site.description }}" />

  <!-- Twitter / X card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ pageTitle }}" />
  <meta name="twitter:description" content="{{ pageDesc }}" />
  <meta name="twitter:image" content="{{ pageImage }}" />
  <meta name="twitter:image:alt" content="{{ site.name }} — {{ site.description }}" />

  <!-- Fonts: Exo 2 (headings) + Inter (body) — loaded async to avoid render-blocking -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Exo+2:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Exo+2:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Exo+2:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" />
  </noscript>

  <link rel="stylesheet" href="/css/site.css" />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  {% include "header.njk" %}

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  {% if site.cfToken %}
  <!-- Cloudflare Web Analytics — cookieless, no consent required -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon='{"token": "{{ site.cfToken }}"}'></script>
  {% endif %}

  {% include "cookie-banner.njk" %}

  {% if pageScript %}
  <script src="{{ pageScript }}" defer></script>
  {% endif %}
</body>
</html>
