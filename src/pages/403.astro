---
import ErrorLayout from '../layouts/ErrorLayout.astro';
---

<ErrorLayout
  errorCode={"403"}
  errorTitle={"Access Denied"}
  errorDesc={"You don't have permission to access this resource."}
>
<section class="error-page" aria-labelledby="error-title">
  <div class="container">
    <p class="error-code" aria-hidden="true">403</p>
    <h1 class="error-title" id="error-title">Access Denied</h1>
    <p class="error-desc">
      You don't have permission to access this resource.
      If you think this is a mistake, please get in touch.
    </p>
    <div class="error-actions">
      <a href="https://shadowcomputers.uk/" class="btn-primary">Return to Homepage</a>
      <a href="https://shadowcomputers.uk/contact/" class="btn-secondary">Contact Us</a>
    </div>
  </div>
</section>
</ErrorLayout>
