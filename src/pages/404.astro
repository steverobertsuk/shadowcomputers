---
import ErrorLayout from '../layouts/ErrorLayout.astro';
---

<ErrorLayout
  errorCode={"404"}
  errorTitle={"Page Not Found"}
  errorDesc={"The page you're looking for doesn't exist or has been moved."}
>
<section class="error-page" aria-labelledby="error-title">
  <div class="container">
    <p class="error-code" aria-hidden="true">404</p>
    <h1 class="error-title" id="error-title">Page Not Found</h1>
    <p class="error-desc">
      The page you're looking for doesn't exist or may have been moved.
      Check the URL or head back to the homepage.
    </p>
    <a href="https://shadowcomputers.co.uk/" class="btn-primary">Return to Homepage</a>
  </div>
</section>
</ErrorLayout>
