{
  "name": "shadow-computers",
  "version": "1.0.4",
  "description": "Shadow Computers website — Hosting, Web & Media Systems",
  "scripts": {
    "build": "cross-env NODE_ENV=production eleventy && node ./scripts/check-accessible-names.mjs _site",
    "start": "eleventy --serve --port=8081",
    "watch": "node ./scripts/watch.mjs",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "prettier": "^3.8.3"
  }
}
