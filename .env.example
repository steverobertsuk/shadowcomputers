# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
GA_MEASUREMENT_ID=

# Cloudflare Web Analytics — Beacon token
CF_BEACON_TOKEN=

# Cloudflare Turnstile — public site key (safe to expose in HTML)
# Create a widget at https://dash.cloudflare.com → Turnstile
TURNSTILE_SITE_KEY=

# Contact form — Worker / Pages Function environment variables
# These are set in the Cloudflare Pages dashboard (Settings > Environment variables)
# and are NOT needed in .env for local Eleventy builds.
#
# TURNSTILE_SECRET=        (Turnstile secret key — server-side only)
# CONTACT_EMAIL=           (destination address, e.g. hello@shadowcomputers.co.uk)
# FROM_EMAIL=              (sending address, must be verified in Cloudflare Email Routing)
