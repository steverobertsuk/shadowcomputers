---
import BaseLayout from '../layouts/BaseLayout.astro';
import BgBracket from '../components/BgBracket.astro';
---

<BaseLayout
  title={"Hosting, Web & Media Systems"}
  description={"Shadow Computers — Hosting, Web & Media Systems with part-time IT Support. Remote support, Microsoft 365, hosting, web development, and media workflows."}
>
<!-- ══ HERO ══════════════════════════════════════════════ -->
<section class="hero" aria-labelledby="hero-title">
  <BgBracket />
  <div class="container">
    <div class="hero-layout">
      <div class="hero-left">
        <p class="hero-eyebrow">Hosting, Web &amp; Media Systems</p>
        <h1 class="hero-title" id="hero-title">
          <em>Shadow</em> Computers
        </h1>
        <p class="hero-sub">
          Hands-on experience across remote support, Microsoft&nbsp;365, hosting,
          full-stack development, and media production workflows.
        </p>
      </div>
      <div class="hero-right">
        <div class="hero-areas" role="list" aria-label="Core service areas">
          <span class="area-pill" role="listitem">Remote Support &amp; Troubleshooting</span>
          <span class="area-pill" role="listitem">Microsoft 365 &amp; Exchange Online</span>
          <span class="area-pill" role="listitem">Hosting &amp; Infrastructure</span>
          <span class="area-pill" role="listitem">Websites</span>
          <span class="area-pill" role="listitem">Web Applications</span>
          <span class="area-pill" role="listitem">Media &amp; Streaming Systems</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ INTRO STRIP ═══════════════════════════════════════ -->
<section class="intro-strip" aria-label="Overview">
  <div class="container">
    <p>
      Shadow Computers focuses on real systems, real users, and real environments —
      covering remote support, Microsoft&nbsp;365, hosting, web development, and
      media&thinsp;/&thinsp;streaming systems.
    </p>
  </div>
</section>

<!-- ══ SERVICES OVERVIEW ═════════════════════════════════ -->
<section class="section" aria-labelledby="services-heading">
  <div class="container">
    <p class="section-label">What I cover</p>
    <h2 class="section-heading" id="services-heading">Services</h2>
    <div class="divider" aria-hidden="true"></div>
    <p class="section-lead">
      Work is carried out on a limited, ad hoc basis outside normal working hours,
      supporting families and small businesses with practical, real-world solutions.
    </p>

    <div class="services-grid">

      <article class="service-card">
        <div class="service-card-icon" aria-hidden="true">
          <i class="fa-solid fa-server"></i>
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title">Hosting &amp; Infrastructure</h3>
          <p class="service-card-desc">Managing hosting environments, DNS configuration, domains, and deployments.</p>
          <ul class="service-card-list">
            <li>DNS and domain management</li>
            <li>Hosting platforms and environments</li>
            <li>Deployment configuration and maintenance</li>
          </ul>
        </div>
      </article>

      <article class="service-card">
        <div class="service-card-icon" aria-hidden="true">
          <i class="fa-solid fa-globe"></i>
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title">Websites</h3>
          <p class="service-card-desc">Building and maintaining websites across static builds, WordPress, and Concrete CMS.</p>
          <ul class="service-card-list">
            <li>Site setup and configuration</li>
            <li>Ongoing maintenance and updates</li>
            <li>Performance optimisation</li>
          </ul>
        </div>
      </article>

      <article class="service-card">
        <div class="service-card-icon" aria-hidden="true">
          <i class="fa-solid fa-code"></i>
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title">Web Applications</h3>
          <p class="service-card-desc">Developing and maintaining web applications using modern frameworks, focusing on reliability and maintainability.</p>
          <ul class="service-card-list">
            <li>Angular frontend frameworks</li>
            <li>NestJS backend services</li>
            <li>PostgreSQL &amp; REST APIs</li>
          </ul>
        </div>
      </article>

      <article class="service-card">
        <div class="service-card-icon" aria-hidden="true">
          <i class="fa-solid fa-desktop"></i>
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title">Remote Support</h3>
          <p class="service-card-desc">Diagnosing and resolving system issues remotely, including performance problems, software faults, and configuration issues.</p>
          <ul class="service-card-list">
            <li>Remote desktop support</li>
            <li>Windows system troubleshooting</li>
            <li>Performance optimisation</li>
          </ul>
        </div>
      </article>

      <article class="service-card">
        <div class="service-card-icon" aria-hidden="true">
          <i class="fa-brands fa-microsoft"></i>
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title">Microsoft 365</h3>
          <p class="service-card-desc">Working with Microsoft 365 tenants, including Exchange Online setup, mailbox configuration, and administration.</p>
          <ul class="service-card-list">
            <li>Tenant configuration</li>
            <li>Exchange Online setup</li>
            <li>Mailbox management</li>
          </ul>
        </div>
      </article>

      <article class="service-card">
        <div class="service-card-icon" aria-hidden="true">
          <i class="fa-solid fa-tower-broadcast"></i>
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title">Media &amp; Streaming Systems</h3>
          <p class="service-card-desc">Designing and managing live and recorded media workflows, including streaming, recording, and post-production.</p>
          <ul class="service-card-list">
            <li>Live streaming setup (RTMP, simulcasting)</li>
            <li>Broadcast configuration and scene management</li>
            <li>Video and audio editing workflows</li>
          </ul>
        </div>
      </article>

    </div>
  </div>
</section>
</BaseLayout>
